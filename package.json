{
  "name": "reseed",
  "version": "2.3.0",
  "description": "Reseed is an open-source tool for integrating static sites into subpaths.",
  "main": "index.js",
  "scripts": {
    "lint": "biome check --fix && tsc --noEmit -p jsconfig.json",
    "lint:report": "biome lint --diagnostic-level=error --reporter=junit > lint-results.xml",
    "lint:staged": "biome check --diagnostic-level=error --staged --no-errors-on-unmatched",
    "test": "node --experimental-strip-types --test",
    "test:watch": "node --experimental-strip-types --test --watch",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudCannon/reseed.git"
  },
  "bugs": {
    "url": "https://github.com/CloudCannon/reseed/issues"
  },
  "homepage": "https://github.com/CloudCannon/reseed#readme",
  "keywords": [
    "CloudCannon",
    "Reseed",
    "Subpath",
    "href",
    "url",
    "link"
  ],
  "author": "CloudCannon",
  "license": "MIT",
  "files": [
    "lib",
    "cli.js",
    "index.js"
  ],
  "bin": {
    "reseed": "index.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "ansi-colors": "^4.1.3",
    "browser-sync": "^3.0.3",
    "cheerio": "1.2.0",
    "chokidar": "^5.0.0",
    "cssurl": "^1.3.0",
    "fancy-log": "^2.0.0",
    "glob": "^13.0.6",
    "meow": "^14.1.0",
    "path": "^0.12.7",
    "readline-sync": "^1.4.10",
    "srcset": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "mock-fs": "^5.5.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.3",
    "typescript": "^6.0.2"
  }
}
